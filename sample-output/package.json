{
  "name": "taskmanager-api",
  "version": "1.0.0",
  "description": "TaskManager API - Production-grade serverless backend generated by the Serverless API Accelerator prompt",
  "main": "index.js",
  "scripts": {
    "test": "jest --passWithNoTests",
    "deploy": "sam deploy",
    "deploy:guided": "sam deploy --guided",
    "build": "sam build",
    "invoke:create": "sam local invoke CreateTaskFunction -e events/create-task.json",
    "invoke:list": "sam local invoke ListTasksFunction -e events/list-tasks.json",
    "invoke:get": "sam local invoke GetTaskFunction -e events/get-task.json",
    "invoke:update": "sam local invoke UpdateTaskFunction -e events/update-task.json",
    "invoke:delete": "sam local invoke DeleteTaskFunction -e events/delete-task.json",
    "start:api": "sam local start-api",
    "logs": "sam logs --stack-name prompt-the-planet-taskmanager-prod --tail"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.0.0",
    "@aws-lambda-powertools/metrics": "^2.0.0",
    "@aws-lambda-powertools/tracer": "^2.0.0",
    "@aws-sdk/client-dynamodb": "^3.500.0",
    "@aws-sdk/lib-dynamodb": "^3.500.0"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}